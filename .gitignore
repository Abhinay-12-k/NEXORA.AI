# ============================================================
#   SIPA - Smart Internship Performance Analyzer
#   .gitignore | Production-Ready | MERN Stack
# ============================================================


# ─────────────────────────────────────────
# 📦 Dependencies
# ─────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/


# ─────────────────────────────────────────
# 🔐 Environment Variables (NEVER commit these)
# ─────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
backend/.env
frontend/.env


# ─────────────────────────────────────────
# 🏗️ Build & Distribution Outputs
# ─────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/
backend/dist/
backend/build/


# ─────────────────────────────────────────
# 🧪 Test Coverage
# ─────────────────────────────────────────
coverage/
backend/coverage/
frontend/coverage/
*.lcov
.nyc_output/


# ─────────────────────────────────────────
# 📋 Logs
# ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─────────────────────────────────────────
# 💻 OS Generated Files
# ─────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ─────────────────────────────────────────
# 🛠️ IDE & Editor Files
# ─────────────────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*.swn

# Sublime Text
*.sublime-project
*.sublime-workspace


# ─────────────────────────────────────────
# ⚡ Vite / Frontend Specific
# ─────────────────────────────────────────
frontend/.vite/
*.local


# ─────────────────────────────────────────
# 🗄️ Database & Runtime
# ─────────────────────────────────────────
*.sqlite
*.db

# PM2 (Process Manager)
.pm2/

# Diagnostic reports (Node.js)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


# ─────────────────────────────────────────
# 🚀 CI/CD & Deployment Artifacts
# ─────────────────────────────────────────
.vercel/
.netlify/
.serverless/
.cache/


# ─────────────────────────────────────────
# 📌 Misc
# ─────────────────────────────────────────

# Optional npm cache
.npm/

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Yarn Integrity file
.yarn-integrity

# Parcel cache
.parcel-cache/

# Storybook build outputs
.out/
.storybook-out/
